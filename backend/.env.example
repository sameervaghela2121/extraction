PORT=4000
NODE_ENV=development

# Shared MongoDB Atlas cluster (also used by invoice-generator-backend)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/?appName=<app>
MONGODB_DB_NAME=Data
MONGO_FILES_COLLECTION=Files
MONGO_INVOICE_COLLECTION=Invoice

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# invoice-generator-backend integration
INVOICE_GENERATOR_BASE_URL=http://localhost:8000
INVOICE_GENERATOR_APP_USER=
INVOICE_GENERATOR_APP_PASSWORD=

# Frontend origin (CORS)
FRONTEND_ORIGIN=http://localhost:5173

# Mail (invite emails) - optional in dev, logs to console if unset
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@docflow.app
